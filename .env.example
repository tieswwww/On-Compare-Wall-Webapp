# ── ON Compare Wall — environment template ──
# Local config lives in TWO gitignored files. This .example is the only one
# committed; it just documents what to set. All values come from the Supabase
# dashboard → project on-showroom-data (dlcogzpcduadrshlxqrr) → Settings → API.
#
#   .env       → PUBLIC config the BROWSER uses. Vite only exposes VITE_* vars.
#   .dev.vars  → SECRETS the SERVER uses. Never commit. (See its own comments.)

# ---- .env  (public: URL + anon/publishable key are safe in the browser) ----
SUPABASE_URL=https://dlcogzpcduadrshlxqrr.supabase.co
# anon / publishable key (Settings → API):
SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=https://dlcogzpcduadrshlxqrr.supabase.co
# same anon / publishable key as above:
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=dlcogzpcduadrshlxqrr

# ---- .dev.vars  (secrets — NEVER commit) ----
# SUPABASE_SERVICE_ROLE_KEY   = Settings → API → service_role (secret key)
# NODE_RED_PASSWORD           = invent — scanner/ingest auth token
# VIEWER_PASSWORD             = invent — the `viewer` login password
# VIEWER_ACCESS_TOKEN         = invent — kiosk auto-login token (/?k=...)
