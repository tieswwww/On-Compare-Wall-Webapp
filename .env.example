# ── ON Compare Wall — environment template ──
# Copy to `.env` for local dev (`.env` is gitignored). In production these are
# provided by the Lovable / Cloudflare deploy environment, not this file.

# Public Supabase config (anon key + project URL; safe in the browser with RLS).
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Catalog source — on-showroom-data (read-only client).
# 2nd Supabase client used only to prefetch the product catalog view.
CATALOG_SUPABASE_URL=
CATALOG_SUPABASE_ANON_KEY=

# ── Secrets — do NOT put these in .env or git. Use `.dev.vars` (gitignored). ──
# SUPABASE_SERVICE_ROLE_KEY=
# NODE_RED_PASSWORD=
# VIEWER_PASSWORD=
# VIEWER_ACCESS_TOKEN=
