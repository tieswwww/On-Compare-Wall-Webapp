# ── ON Compare Wall — environment template ──
# Local config lives in TWO gitignored files. This .example is the only one
# committed; it just documents what to set. All values come from the Supabase
# dashboard → project on-showroom-data (dlcogzpcduadrshlxqrr) → Settings → API.
#
#   .env       → PUBLIC config the BROWSER uses. Vite only exposes VITE_* vars.
#   .dev.vars  → SECRETS the SERVER uses. Never commit. (See its own comments.)

# ---- .env  (public: URL + anon/publishable key are safe in the browser) ----
SUPABASE_URL=https://dlcogzpcduadrshlxqrr.supabase.co
# anon / publishable key (Settings → API):
SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=https://dlcogzpcduadrshlxqrr.supabase.co
# same anon / publishable key as above:
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=dlcogzpcduadrshlxqrr

# Kiosk mode — the TSS Play installation. Skips the viewer login and reads the
# catalog with the anon key (compare_wall is anon-readable). Leave UNSET (or
# false) for the normal browser/admin build, which keeps the login gate + the
# service-role catalog server fn. See docs/PRODUCTION-RUNTIME-DESIGN.md.
VITE_KIOSK_MODE=false

# Event transport — where live scans arrive (src/lib/transport):
#   realtime (default) → Supabase Realtime broadcast (cloud; dev/admin)
#   mqtt              → local RabbitMQ Web-MQTT broker on the POS (offline)
# Set to mqtt for the installation.
VITE_EVENT_TRANSPORT=realtime
# MQTT (Web-MQTT over WebSocket) — only used when VITE_EVENT_TRANSPORT=mqtt.
# The bridge publishes scan events to topic `shoe-events` on the local broker.
# Confirm the exact host/port/path + creds on the POS.
VITE_MQTT_URL=ws://localhost:15672/ws
VITE_MQTT_TOPIC=shoe-events
VITE_MQTT_USERNAME=
VITE_MQTT_PASSWORD=

# TSS Gateway (RabbitMQ) — installation event broker
TSS_GATEWAY_URL=tsc-nl-ties-control.storytellingsuite.com
TSS_GATEWAY_PORT=5672            # AMQP port (bridge publishes here)
TSS_GATEWAY_USER=location
TSS_GATEWAY_PASSWORD= # <-- put the gateway password here (keep out of git)

# MQTT topic the bridge publishes scan events to (same {event_type,side,ean} JSON)
TSS_GATEWAY_TOPIC=shoe-events
